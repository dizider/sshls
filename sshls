#!/bin/bash

format_entry() {
    local host="$1" hostname="$2" user="$3" port="$4" identity="$5" tags="$6"
    printf '\n'
    [ -n "$tags" ] && printf '# Tags: %s\n' "$tags"
    printf 'Host %s\n' "$host"
    printf '    HostName %s\n' "$hostname"
    printf '    User %s\n' "$user"
    [ -n "$port" ] && printf '    Port %s\n' "$port"
    [ -n "$identity" ] && printf '    IdentityFile %s\n' "$identity"
}

host_exists() {
    local alias="$1" config="$2"
    [ -f "$config" ] || return 1
    awk -v a="$alias" '
        /^Host / {
            for (i = 2; i <= NF; i++) if ($i == a) { found = 1; exit }
        }
        END { exit !found }
    ' "$config"
}

# Exit 0 if TEXT contains a well-formed numeric range token {N..N} or {N..N..N}.
has_range() {
    [[ "$1" =~ \{[0-9]+\.\.[0-9]+(\.\.[0-9]+)?\} ]]
}

# Expand TEXT containing at most one numeric range token into multiple lines.
# No token -> TEXT unchanged. Errors (return 1) on >1 token, descending, step<1.
expand_range() {
    local text="$1"
    local re='\{([0-9]+)\.\.([0-9]+)(\.\.([0-9]+))?\}'
    if [[ ! "$text" =~ $re ]]; then
        printf '%s\n' "$text"
        return 0
    fi
    local token="${BASH_REMATCH[0]}"
    local start="${BASH_REMATCH[1]}" end="${BASH_REMATCH[2]}" step="${BASH_REMATCH[4]}"

    # Reject a second range token.
    local rest="${text/"$token"/}"
    if [[ "$rest" =~ $re ]]; then
        echo "expand_range: more than one range token in '$text'" >&2
        return 1
    fi

    [ -z "$step" ] && step=1
    if (( 10#$step < 1 )); then
        echo "expand_range: step must be >= 1 in '$text'" >&2
        return 1
    fi
    if (( 10#$start > 10#$end )); then
        echo "expand_range: descending ranges not supported in '$text'" >&2
        return 1
    fi

    # Zero-pad only if an operand literal has a leading zero ('0' alone excluded).
    local pad=0 width=0
    if [[ "$start" =~ ^0[0-9]+ || "$end" =~ ^0[0-9]+ ]]; then
        pad=1
        width=$(( ${#start} > ${#end} ? ${#start} : ${#end} ))
    fi

    local prefix="${text%%"$token"*}" suffix="${text#*"$token"}"
    local i num
    for (( i = 10#$start; i <= 10#$end; i += 10#$step )); do
        if [ "$pad" = 1 ]; then
            printf -v num '%0*d' "$width" "$i"
        else
            num="$i"
        fi
        printf '%s%s%s\n' "$prefix" "$num" "$suffix"
    done
}

# Expand all six fields, zip by index, broadcast constants. Print N tab-separated
# rows. Errors on expand failure, mismatched range counts, or duplicate aliases.
build_cluster() {
    local out
    local -a a_host a_name a_user a_port a_id a_tags
    out=$(expand_range "$1") || return 1; mapfile -t a_host <<<"$out"
    out=$(expand_range "$2") || return 1; mapfile -t a_name <<<"$out"
    out=$(expand_range "$3") || return 1; mapfile -t a_user <<<"$out"
    out=$(expand_range "$4") || return 1; mapfile -t a_port <<<"$out"
    out=$(expand_range "$5") || return 1; mapfile -t a_id   <<<"$out"
    out=$(expand_range "$6") || return 1; mapfile -t a_tags <<<"$out"

    # Common count N among fields with count > 1.
    local n=1 c
    for c in "${#a_host[@]}" "${#a_name[@]}" "${#a_user[@]}" \
             "${#a_port[@]}" "${#a_id[@]}" "${#a_tags[@]}"; do
        if [ "$c" -gt 1 ]; then
            if [ "$n" -eq 1 ]; then
                n="$c"
            elif [ "$c" -ne "$n" ]; then
                echo "build_cluster: range fields have mismatched counts ($n vs $c)" >&2
                return 1
            fi
        fi
    done

    # Broadcast length-1 arrays to length n.
    local -n arr
    local name k
    for name in a_host a_name a_user a_port a_id a_tags; do
        local -n arr="$name"
        if [ "${#arr[@]}" -eq 1 ]; then
            for (( k = 1; k < n; k++ )); do arr[k]="${arr[0]}"; done
        fi
    done

    # Reject duplicate aliases within the batch.
    if [ "$n" -gt 1 ]; then
        local dupes
        dupes=$(printf '%s\n' "${a_host[@]}" | sort | uniq -d)
        if [ -n "$dupes" ]; then
            echo "build_cluster: would create duplicate aliases; put the range in the Host field too" >&2
            return 1
        fi
    fi

    local i
    for (( i = 0; i < n; i++ )); do
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
            "${a_host[i]}" "${a_name[i]}" "${a_user[i]}" \
            "${a_port[i]}" "${a_id[i]}" "${a_tags[i]}"
    done
}

add_cluster() {
    local config="$HOME/.ssh/config"
    local rows
    rows=$(build_cluster "$@") || return   # reason already printed to stderr

    local -a r_host r_name r_user r_port r_id r_tags
    local h hn u p id t
    while IFS=$'\t' read -r h hn u p id t; do
        r_host+=("$h"); r_name+=("$hn"); r_user+=("$u")
        r_port+=("$p"); r_id+=("$id");  r_tags+=("$t")
    done <<<"$rows"
    local n=${#r_host[@]}

    # Drop nodes whose alias already exists.
    local -a keep=() skipped=()
    local i
    for (( i = 0; i < n; i++ )); do
        if host_exists "${r_host[i]}" "$config"; then
            skipped+=("${r_host[i]}")
        else
            keep+=("$i")
        fi
    done
    [ "${#skipped[@]}" -gt 0 ] && echo "Skipping existing: ${skipped[*]}" >&2
    if [ "${#keep[@]}" -eq 0 ]; then
        echo "All ${n} node(s) already exist; nothing to add." >&2
        return
    fi

    # Parallel connection test; collect per-job status via wait PID.
    echo "Testing ${#keep[@]} node(s) ..." >&2
    local -a ssh_common=(-o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new)
    local -A pid_of=()
    local idx target dest
    for idx in "${keep[@]}"; do
        target="${r_name[idx]:-${r_host[idx]}}"
        dest="$target"
        [ -n "${r_user[idx]}" ] && dest="${r_user[idx]}@$target"
        local -a a=("${ssh_common[@]}")
        [ -n "${r_port[idx]}" ] && a+=(-p "${r_port[idx]}")
        [ -n "${r_id[idx]}" ]   && a+=(-i "${r_id[idx]}")
        ssh "${a[@]}" "$dest" true >/dev/null 2>&1 &
        pid_of[$idx]=$!
    done

    local -A passed=()
    for idx in "${keep[@]}"; do
        if wait "${pid_of[$idx]}"; then passed[$idx]=1; else passed[$idx]=0; fi
    done

    for idx in "${keep[@]}"; do
        if [ "${passed[$idx]}" = 1 ]; then
            printf '  OK    %s  ->  %s\n' "${r_host[idx]}" "${r_name[idx]:-${r_host[idx]}}" >&2
        else
            printf '  FAIL  %s  ->  %s\n' "${r_host[idx]}" "${r_name[idx]:-${r_host[idx]}}" >&2
        fi
    done

    local answer
    read -r -p "Save all / only passing / abort? [a/p/N] " answer
    local -a tosave=()
    case "$answer" in
        a|A) tosave=("${keep[@]}") ;;
        p|P) for idx in "${keep[@]}"; do [ "${passed[$idx]}" = 1 ] && tosave+=("$idx"); done ;;
        *)   echo "Aborted, nothing saved." >&2; return ;;
    esac
    if [ "${#tosave[@]}" -eq 0 ]; then
        echo "No nodes to save." >&2
        return
    fi

    if [ ! -f "$config" ]; then
        mkdir -p -m 700 "$HOME/.ssh"
        touch "$config"
        chmod 600 "$config"
    fi

    for idx in "${tosave[@]}"; do
        format_entry "${r_host[idx]}" "${r_name[idx]}" "${r_user[idx]}" \
                     "${r_port[idx]}" "${r_id[idx]}" "${r_tags[idx]}" >> "$config"
    done
    echo "Added ${#tosave[@]} host(s) to $config." >&2
}

add_host() {
    local config="$HOME/.ssh/config"
    local host hostname user port identity tags target
    # Ctrl-C during prompts cancels just the add and returns to the picker,
    # rather than killing the whole script. The RETURN trap guarantees the
    # INT trap is cleared on every exit path.
    trap 'echo >&2; echo "Add cancelled." >&2; return 130' INT
    trap 'trap - INT RETURN' RETURN

    # Host alias — required, must be unique
    while :; do
        read -r -p "Host (alias): " host
        if [ -z "$host" ]; then
            echo "Host alias is required." >&2
            continue
        fi
        if host_exists "$host" "$config"; then
            echo "Host '$host' already exists in $config. Aborting." >&2
            return
        fi
        break
    done

    read -r -p "HostName: " hostname
    [ -z "$hostname" ] && echo "Warning: HostName is empty." >&2
    read -r -p "User: " user
    read -r -p "Port (blank = default): " port
    read -r -p "IdentityFile (blank = none): " identity
    read -r -p "Tags (comma-separated, blank = none): " tags

    # If any field carries a range token, this is a cluster add.
    if has_range "$host" || has_range "$hostname" || has_range "$user" \
       || has_range "$port" || has_range "$identity" || has_range "$tags"; then
        add_cluster "$host" "$hostname" "$user" "$port" "$identity" "$tags"
        return
    fi

    # Connection test
    target="${hostname:-$host}"
    local ssh_args=(-o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new)
    [ -n "$port" ] && ssh_args+=(-p "$port")
    [ -n "$identity" ] && ssh_args+=(-i "$identity")
    local dest="$target"
    [ -n "$user" ] && dest="$user@$target"

    echo "Testing connection to $dest ..." >&2
    if ssh "${ssh_args[@]}" "$dest" true; then
        echo "Connection OK." >&2
    else
        local answer
        read -r -p "Connection test failed. Save anyway? [y/N] " answer
        case "$answer" in
            y|Y) ;;
            *) echo "Aborted, not saved." >&2; return ;;
        esac
    fi

    # Ensure config exists with correct perms
    if [ ! -f "$config" ]; then
        mkdir -p -m 700 "$HOME/.ssh"
        touch "$config"
        chmod 600 "$config"
    fi

    format_entry "$host" "$hostname" "$user" "$port" "$identity" "$tags" >> "$config"
    echo "Added '$host' to $config." >&2
}

if [ "${SSHLS_LIB:-}" != 1 ]; then
    tag_filter="${1:-}"

    if [ "$tag_filter" = "add" ]; then
        add_host
        tag_filter=""
    fi

    while true; do
        entries=$(awk '
            /^Host / {
                if (host != "" && host !~ /[*?]/ && tags !~ /(^|,)[[:space:]]*ignore[[:space:]]*(,|$)/) {
                    if (tags != "") printf "%s\t[%s]\n", host, tags
                    else print host
                }
                host = $2
                tags = pending_tags
                pending_tags = ""
            }
            /^[[:space:]]*#[[:space:]]*[Tt]ags:/ {
                sub(/^[[:space:]]*#[[:space:]]*[Tt]ags:[[:space:]]*/, "")
                pending_tags = $0
            }
            END {
                if (host != "" && host !~ /[*?]/ && tags !~ /(^|,)[[:space:]]*ignore[[:space:]]*(,|$)/) {
                    if (tags != "") printf "%s\t[%s]\n", host, tags
                    else print host
                }
            }
        ' ~/.ssh/config)

        if [ -n "$tag_filter" ]; then
            entries=$(echo "$entries" | awk -F'\t' -v tag="$tag_filter" 'NF>1 && $2 ~ "([\\[,][[:space:]]*)" tag "([[:space:]]*(,|\\]))"')
        fi

        table=$(echo "$entries" | sort | column -t -s $'\t')

        fzf_out=$(echo "$table" | fzf --height 15 --expect=ctrl-a \
            --header 'Enter: connect  Ctrl-A: add host' \
            --preview 'host=$(echo {} | awk "{print \$1}"); awk -v host="$host" "/^[[:space:]]*#[[:space:]]*[Tt]ags:/{if (!found) last_tags=\$0; next} /^Host /{if (found) exit; if (\$2==host){found=1; if (last_tags!=\"\") print last_tags}; last_tags=\"\"} found{print}" ~/.ssh/config')

        key=$(printf '%s\n' "$fzf_out" | sed -n 1p)
        selected=$(printf '%s\n' "$fzf_out" | sed -n 2p)

        if [ "$key" = "ctrl-a" ]; then
            add_host
            continue
        fi

        [ -z "$selected" ] && break

        host=$(echo "$selected" | awk '{print $1}')
        TERM=xterm-256color ssh "$host"
    done
fi
